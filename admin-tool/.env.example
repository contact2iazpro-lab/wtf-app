# ── Client-side vars (exposed in Vite bundle, prefixed VITE_) ───────────────

# Supabase — get from https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# ⚠️ Service role key bypasses all RLS — keep tool access restricted via VITE_ADMIN_PASSWORD
VITE_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin tool password — single shared password for all admins
VITE_ADMIN_PASSWORD=your-strong-password-here

# Anthropic API key — used for automatic fact generation (optional)
# Get from https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_KEY=sk-ant-...

# Base URL of the game app — used to resolve legacy relative image paths (/assets/facts/1.png)
# Facts migrated from facts.js store relative paths served by the game domain, not the admin tool.
# Override only if you deploy the game app to a different domain.
VITE_GAME_BASE_URL=https://wtf-app-livid.vercel.app

# ── Server-side vars (Vercel only, never in VITE bundle) ─────────────────────
# These must be set in Vercel dashboard → Project Settings → Environment Variables
# They are NOT prefixed with VITE_ and are NEVER exposed to the browser.

# Same values as above but server-side (for the /api/sync-facts serverless function)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
ADMIN_PASSWORD=your-strong-password-here

# GitHub Personal Access Token — required for the Sync button
# Create at: https://github.com/settings/tokens/new
# Required scopes: repo (full control of private repositories)
# OR: contents:write (fine-grained token for just this repo)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
